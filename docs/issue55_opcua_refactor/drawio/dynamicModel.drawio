  <diagram id="0V2wj8d9DpWRs1DfRTuP" name="StateRegistry">
    <mxGraphModel dx="3183" dy="921" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class StateRegistry {\n        -current_state: Rc~RefCell~Vec~Cell~f64~~~~\n        -evaluation_state: Rc~RefCell~Vec~Cell~f64~~~~\n        -index: HashMap~String, usize~\n        -pending_requests: Vec~String, Proxy~\n\n        +shared() Rc~RefCell~StateRegistry~~\n        +subscribe(offers: &amp;[&amp;str], needs: &amp;[&amp;str]) (Vec~Proxy~, Vec~Proxy~)\n        +resolve() Result~(), String~\n        +commit()\n        +read(key: &amp;str) Option~f64~\n        +read_proxy(key: &amp;str) Result~ReadProxy, String~\n        +snapshot() Vec~StateSlot~\n    }\n\n    class Proxy {\n        -buffer: Rc~RefCell~Vec~Cell~f64~~~~\n        -index: Rc~Cell~usize~~\n\n        +get() f64\n        +set(value: f64)\n    }\n\n    class ReadProxy {\n        -buffer: Rc~RefCell~Vec~Cell~f64~~~~\n        -index: usize\n\n        +get() f64\n    }\n\n    class StateSlot {\n        +key: String\n        +value: f64\n    }\n\n    class RegistryView {\n        -registry: Rc~RefCell~StateRegistry~~\n\n        +read(key: &amp;str) Option~f64~\n        +read_proxy(key: &amp;str) Result~ReadProxy, String~\n        +snapshot() Vec~StateSlot~\n    }\n\n    class Sensor {\n        -proxy: ReadProxy\n        -behavior: Box~dyn SensorBehavior~\n\n        +new(view: RegistryView, key: &amp;str, behavior: Box~dyn SensorBehavior~) Result~Sensor, String~\n        +read() f64\n    }\n\n    class SensorBehavior {\n        &lt;&lt;interface&gt;&gt;\n        +apply(value: f64) f64\n    }\n\n    class DynamicModel {\n        &lt;&lt;interface&gt;&gt;\n        +subscribe(registry: Rc~RefCell~StateRegistry~~)\n        +evaluate()\n    }\n\n    StateRegistry --&gt; Proxy : creates for evaluation_state\n    StateRegistry --&gt; ReadProxy : creates for current_state\n    StateRegistry --&gt; StateSlot : snapshot metadata\n\n    RegistryView --&gt; StateRegistry : read-only facade\n    RegistryView --&gt; ReadProxy : resolves once\n\n    Sensor --&gt; ReadProxy : reads confirmed value\n    Sensor --&gt; SensorBehavior : applies transformation\n\n    DynamicModel --&gt; StateRegistry : offers / needs\n    Proxy --&gt; StateRegistry : points to evaluation_state\n    ReadProxy --&gt; StateRegistry : points to current_state&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="9GJZZyZrNoLVnp14qoA9-18">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry height="405" width="1266" as="geometry" />
