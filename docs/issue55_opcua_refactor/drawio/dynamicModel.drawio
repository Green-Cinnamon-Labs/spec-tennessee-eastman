      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class DynamicModel {\n        &lt;&lt;interface&gt;&gt;\n        +id() ComponentId\n        +label() String\n        +state_size() usize\n\n        +evaluate(input: EvaluationInput, state: EvaluationState) EvaluationOutput\n        +derivatives(input: EvaluationInput, state: EvaluationState) DerivativeOutput\n\n        +set_state(state: EvaluationState)\n        +get_state() EvaluationState\n    }\n\n    class CompositeDynamicModel {\n        &lt;&lt;interface&gt;&gt;\n        +components() Vec~DynamicModel~\n        +state_layout() StateLayout\n        +evaluation_plan() EvaluationPlan\n    }\n\n    class EvaluationInput {\n        +time: f64\n        +dt: f64\n        +commands: Vec~f64~\n        +disturbances: Vec~f64~\n    }\n\n    class EvaluationState {\n        +values: Vec~f64~\n    }\n\n    class EvaluationOutput {\n        +values: Vec~f64~\n    }\n\n    class DerivativeOutput {\n        +yp: Vec~f64~\n    }\n\n    class StateLayout {\n        +offsets: Vec~usize~\n        +sizes: Vec~usize~\n    }\n\n    class EvaluationPlan {\n        +steps: Vec~ComponentId~\n    }\n\n    class ComponentId {\n        +value: String\n    }\n\n    DynamicModel &lt;|-- CompositeDynamicModel\n\n    DynamicModel --&gt; ComponentId\n    DynamicModel --&gt; EvaluationInput\n    DynamicModel --&gt; EvaluationState\n    DynamicModel --&gt; EvaluationOutput\n    DynamicModel --&gt; DerivativeOutput\n\n    CompositeDynamicModel o-- DynamicModel\n    CompositeDynamicModel o-- StateLayout\n    CompositeDynamicModel o-- EvaluationPlan\n\n    EvaluationPlan --&gt; ComponentId&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="hFVUuBqGhU4FO6V6Uhwh-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
