        <UserObject label="points to current_state" mermaidId="e:ReadProxy-&gt;StateRegistry#0" mermaidBaseStyle="curved=1;startArrow=none;endArrow=classic;endSize=9;strokeColor=light-dark(#333333,#cccccc);html=1;fontSize=16;labelBackgroundColor=light-dark(#ECECFF,#1f2020);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontColor=light-dark(#333333,#cccccc);exitX=0;exitY=0.4226190476190476;exitDx=0;exitDy=0;entryX=1;entryY=0.4638888888888889;entryDx=0;entryDy=0;curved=1;exitX=0;exitY=0.42;entryX=1;entryY=0.46;" mermaidBaseValue="points to current_state" id="9GJZZyZrNoLVnp14qoA9-75">
          <mxCell edge="1" parent="9GJZZyZrNoLVnp14qoA9-18" source="9GJZZyZrNoLVnp14qoA9-38" style="startArrow=none;endArrow=classic;endSize=9;strokeColor=light-dark(#333333,#cccccc);html=1;fontSize=16;labelBackgroundColor=light-dark(#ECECFF,#1f2020);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontColor=light-dark(#333333,#cccccc);rounded=0;edgeStyle=orthogonalEdgeStyle;" target="9GJZZyZrNoLVnp14qoA9-19">
