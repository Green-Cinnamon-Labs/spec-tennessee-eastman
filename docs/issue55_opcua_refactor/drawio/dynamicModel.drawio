  <diagram id="0V2wj8d9DpWRs1DfRTuP" name="StateRegistry">
    <mxGraphModel dx="1645" dy="875" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class DynamicModel {\n        &lt;&lt;interface&gt;&gt;\n\n        +name() &amp;&#39;static str\n        +get_state_template() StateTemplate\n        +evaluate(state: &amp;[f64]) EvaluationResult\n        +set_state(state: &amp;[f64]) StateRegistry\n    }\n\n    class StateTemplate {\n        +size: usize\n\n        +new(size: usize) StateTemplate\n        +empty() StateTemplate\n        +len() usize\n        +is_empty() bool\n    }\n\n    class EvaluationResult {\n        +derivatives: Vec~f64~\n        +values: HashMap~String, f64~\n\n        +new(derivatives: Vec~f64~) EvaluationResult\n        +with_value(key: String, value: f64) EvaluationResult\n        +set_value(key: String, value: f64)\n        +get_value(key: String) Option~f64~\n        +has_value(key: String) bool\n        +derivative_at(index: usize) f64\n    }\n\n    class StateRegistry {\n        +state: Vec~f64~\n\n        +new(state: Vec~f64~) StateRegistry\n        +from_template(template: StateTemplate) StateRegistry\n        +get(index: usize) f64\n        +set(index: usize, value: f64)\n        +as_slice() &amp;[f64]\n        +len() usize\n    }\n\n    DynamicModel --&gt; StateTemplate : get_state_template()\n    DynamicModel --&gt; EvaluationResult : evaluate()\n    DynamicModel --&gt; StateRegistry : set_state()\n\n    EvaluationResult --&gt; StateTemplate : derivatives.len() should match size\n    StateRegistry --&gt; StateTemplate : can be created from&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="shnlBWu45BSGk19akHMa-41">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
