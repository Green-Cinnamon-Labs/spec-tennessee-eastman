        <UserObject label="points to evaluation_state" mermaidId="e:Proxy-&gt;StateRegistry#0" mermaidBaseStyle="curved=1;startArrow=none;endArrow=classic;endSize=9;strokeColor=light-dark(#333333,#cccccc);html=1;fontSize=16;labelBackgroundColor=light-dark(#ECECFF,#1f2020);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontColor=light-dark(#333333,#cccccc);exitX=1;exitY=0.4322916666666667;exitDx=0;exitDy=0;entryX=0;entryY=0.4638888888888889;entryDx=0;entryDy=0;curved=1;exitX=1;exitY=0.43;entryX=0;entryY=0.46;" mermaidBaseValue="points to evaluation_state" id="9GJZZyZrNoLVnp14qoA9-74">
