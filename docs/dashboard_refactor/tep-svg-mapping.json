{
  "$schema": "TEP SVG Semantic Mapping",
  "title": "Tennessee Eastman Process — SVG ID and Data-Attribute Mapping",
  "description": "Translates abstract ontology (XMV, XMEAS, streams) to concrete SVG semantic structure (id, class, data-*). Source of truth for drawing and JavaScript binding.",
  "version": "1.0.0",
  "date": "2026-05-20",

  "units": [
    {
      "svg_id": "unit-reactor",
      "svg_class": "unit vessel",
      "svg_parent": "#units",
      "name": "Reactor",
      "data_unit": "reactor",
      "xmeas_inline": [7, 8, 9],
      "xmeas_description": "pressure (7), level (8), temperature (9)",
      "xmv_controlled_by": [3, 4, 5, 10, 12],
      "note": "Reator onde as reações químicas ocorrem (TCR, exotérmico)"
    },
    {
      "svg_id": "unit-condenser",
      "svg_class": "unit heat-exchanger",
      "svg_parent": "#units",
      "name": "Condenser",
      "data_unit": "condenser",
      "xmeas_inline": [],
      "xmv_controlled_by": [11],
      "note": "Condensa produto do reator (não é acumulador, sem holdup dinâmico)"
    },
    {
      "svg_id": "unit-separator",
      "svg_class": "unit vessel",
      "svg_parent": "#units",
      "name": "Separator",
      "data_unit": "separator",
      "xmeas_inline": [11, 12, 13, 14],
      "xmeas_description": "temperature (11), level (12), pressure (13), underflow (14)",
      "xmv_controlled_by": [7, 11],
      "note": "Vapor-liquid separator; separa vapor reciclável/purga e líquido"
    },
    {
      "svg_id": "unit-compressor",
      "svg_class": "unit machine",
      "svg_parent": "#units",
      "name": "Compressor",
      "data_unit": "compressor",
      "xmeas_inline": [20],
      "xmeas_description": "work (20)",
      "xmv_controlled_by": [5],
      "note": "Recycle compressor; recicla vapor não condensado"
    },
    {
      "svg_id": "unit-stripper",
      "svg_class": "unit vessel",
      "svg_parent": "#units",
      "name": "Stripper",
      "data_unit": "stripper",
      "xmeas_inline": [15, 16, 18, 19],
      "xmeas_description": "level (15), pressure (16), temperature (18), steam-flow (19)",
      "xmv_controlled_by": [8, 9],
      "note": "Product stripper; remove componentes leves do produto líquido"
    }
  ],

  "streams": [
    {
      "svg_id": "stream-01-a-feed",
      "svg_class": "stream gas feed",
      "svg_parent": "#streams",
      "stream_number": 1,
      "name": "A Feed",
      "data_stream": "1",
      "data_xmeas": "1",
      "data_xmv": "3",
      "data_phase": "gas",
      "description": "Alimentação A (composto A puro, gasoso)",
      "source": "external",
      "destination": "unit-reactor"
    },
    {
      "svg_id": "stream-02-d-feed",
      "svg_class": "stream gas-feed feed",
      "svg_parent": "#streams",
      "stream_number": 2,
      "name": "D Feed",
      "data_stream": "2",
      "data_xmeas": "2",
      "data_xmv": "1",
      "data_phase": "gas-feed",
      "description": "Alimentação D (reage como D(g) no reator; fase: gasosa)",
      "source": "external",
      "destination": "unit-reactor"
    },
    {
      "svg_id": "stream-03-e-feed",
      "svg_class": "stream gas-feed feed",
      "svg_parent": "#streams",
      "stream_number": 3,
      "name": "E Feed",
      "data_stream": "3",
      "data_xmeas": "3",
      "data_xmv": "2",
      "data_phase": "gas-feed",
      "description": "Alimentação E (reage como E(g) no reator; fase: gasosa)",
      "source": "external",
      "destination": "unit-reactor"
    },
    {
      "svg_id": "stream-04-ac-feed",
      "svg_class": "stream gas feed",
      "svg_parent": "#streams",
      "stream_number": 4,
      "name": "A/C Feed",
      "data_stream": "4",
      "data_xmeas": "4",
      "data_xmv": "4",
      "data_phase": "gas",
      "description": "Alimentação A + C (razão variável por IDV 1); vai direto ao stripper, não ao reator",
      "source": "external",
      "destination": "unit-stripper"
    },
    {
      "svg_id": "stream-05-stripper-overhead",
      "svg_class": "stream gas overhead recycle",
      "svg_parent": "#streams",
      "stream_number": 5,
      "name": "Stripper Overhead",
      "data_stream": "5",
      "data_phase": "gas",
      "description": "Topo do stripper retorna ao nó de mistura de alimentação do reator",
      "source": "unit-stripper",
      "destination": "node-reactor-feed-mixer"
    },
    {
      "svg_id": "stream-06-reactor-feed",
      "svg_class": "stream mixed reactor-feed",
      "svg_parent": "#streams",
      "stream_number": 6,
      "name": "Reactor Feed (Total)",
      "data_stream": "6",
      "data_xmeas": "6",
      "data_phase": "mixed",
      "data_analyzer": "analyzer-reactor-feed",
      "description": "Saída do nó de mistura (stream-01 + stream-02 + stream-03 + stream-05 + stream-08) para o reator; ponto de amostragem XMEAS 23-28",
      "source": "node-reactor-feed-mixer",
      "destination": "unit-reactor"
    },
    {
      "svg_id": "stream-07-reactor-product",
      "svg_class": "stream vapor product",
      "svg_parent": "#streams",
      "stream_number": 7,
      "name": "Reactor Product",
      "data_stream": "7",
      "data_phase": "vapor",
      "description": "Saída do reator: reator → condenser → separator (condenser é intermediário sem holdup principal)",
      "source": "unit-reactor",
      "destination": "unit-separator",
      "passes_through": "unit-condenser"
    },
    {
      "svg_id": "stream-08-recycle",
      "svg_class": "stream gas recycle",
      "svg_parent": "#streams",
      "stream_number": 8,
      "name": "Recycle",
      "data_stream": "8",
      "data_xmeas": "5",
      "data_xmv": "5",
      "data_phase": "gas",
      "description": "Vapor reciclado do compressor para reator",
      "source": "unit-compressor",
      "destination": "unit-reactor"
    },
    {
      "svg_id": "stream-09-purge",
      "svg_class": "stream gas purge",
      "svg_parent": "#streams",
      "stream_number": 9,
      "name": "Purge",
      "data_stream": "9",
      "data_xmeas": "10",
      "data_xmv": "6",
      "data_phase": "gas",
      "data_analyzer": "analyzer-purge",
      "description": "Purga da linha vapor/não-condensados associada ao separador/reciclo (inertes, A em excesso); ponto de amostragem XMEAS 29-36",
      "source": "unit-separator",
      "source_port": "vapor_out",
      "source_region": "separator_recycle_header",
      "destination": "external"
    },
    {
      "svg_id": "stream-10-separator-liquid",
      "svg_class": "stream liquid separator-underflow",
      "svg_parent": "#streams",
      "stream_number": 10,
      "name": "Separator Underflow",
      "data_stream": "10",
      "data_xmeas": "14",
      "data_xmv": "7",
      "data_phase": "liquid",
      "description": "Líquido do separador para stripper (bottoms)",
      "source": "unit-separator",
      "destination": "unit-stripper"
    },
    {
      "svg_id": "stream-11-product",
      "svg_class": "stream liquid product",
      "svg_parent": "#streams",
      "stream_number": 11,
      "name": "Product",
      "data_stream": "11",
      "data_xmeas": "17",
      "data_xmv": "8",
      "data_phase": "liquid",
      "data_analyzer": "analyzer-product",
      "description": "Produto final (saída do stripper); ponto de amostragem XMEAS 37-41",
      "source": "unit-stripper",
      "destination": "external"
    },
    {
      "svg_id": "stream-12-reactor-cw",
      "svg_class": "stream utility cooling-water reactor-cw",
      "svg_parent": "#utilities",
      "stream_number": 12,
      "name": "Reactor CW",
      "data_stream": "12",
      "data_xmv": "10",
      "data_xmeas": "21",
      "data_phase": "utility",
      "description": "Água de resfriamento para jaqueta do reator (outlet: XMEAS 21)",
      "source": "external",
      "destination": "unit-reactor",
      "utility_type": "cooling-water"
    },
    {
      "svg_id": "stream-13-condenser-cw",
      "svg_class": "stream utility cooling-water condenser-cw",
      "svg_parent": "#utilities",
      "stream_number": 13,
      "name": "Condenser CW",
      "data_stream": "13",
      "data_xmv": "11",
      "data_xmeas": "22",
      "data_phase": "utility",
      "description": "Água de resfriamento para condensador (outlet: XMEAS 22)",
      "source": "external",
      "destination": "unit-condenser",
      "utility_type": "cooling-water"
    }
  ],

