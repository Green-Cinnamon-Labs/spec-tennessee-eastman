  "measurements": [
    { "svg_cell_id": "sensor-xmeas-01", "svg_class": "measurement flow-sensor",        "xmeas_number": 1,  "name": "A Feed",                           "data_xmeas": "1",  "data_stream": "1",  "unit": "kscmh", "symbol": "FI" },
    { "svg_cell_id": "sensor-xmeas-02", "svg_class": "measurement flow-sensor",        "xmeas_number": 2,  "name": "D Feed",                           "data_xmeas": "2",  "data_stream": "2",  "unit": "kg/hr", "symbol": "FI" },
    { "svg_cell_id": "sensor-xmeas-03", "svg_class": "measurement flow-sensor",        "xmeas_number": 3,  "name": "E Feed",                           "data_xmeas": "3",  "data_stream": "3",  "unit": "kg/hr", "symbol": "FI" },
    { "svg_cell_id": "sensor-xmeas-04", "svg_class": "measurement flow-sensor",        "xmeas_number": 4,  "name": "A/C Feed",                         "data_xmeas": "4",  "data_stream": "4",  "unit": "kscmh", "symbol": "FI" },
    { "svg_cell_id": "sensor-xmeas-05", "svg_class": "measurement flow-sensor",        "xmeas_number": 5,  "name": "Recycle Flow",                     "data_xmeas": "5",  "data_stream": "8",  "unit": "kscmh", "symbol": "FI" },
    { "svg_cell_id": "sensor-xmeas-06", "svg_class": "measurement flow-sensor",        "xmeas_number": 6,  "name": "Reactor Feed Rate",                "data_xmeas": "6",  "data_stream": "6",  "unit": "kscmh", "symbol": "FI" },
    { "svg_cell_id": "sensor-xmeas-07", "svg_class": "measurement pressure-sensor",    "xmeas_number": 7,  "name": "Reactor Pressure",                 "data_xmeas": "7",  "data_unit": "unit-reactor",     "unit": "kPa",   "symbol": "PI", "critical": true },
    { "svg_cell_id": "sensor-xmeas-08", "svg_class": "measurement level-sensor",       "xmeas_number": 8,  "name": "Reactor Level",                    "data_xmeas": "8",  "data_unit": "unit-reactor",     "unit": "%",     "symbol": "LI", "critical": true },
    { "svg_cell_id": "sensor-xmeas-09", "svg_class": "measurement temperature-sensor", "xmeas_number": 9,  "name": "Reactor Temperature",              "data_xmeas": "9",  "data_unit": "unit-reactor",     "unit": "°C",    "symbol": "TI", "critical": true },
    { "svg_cell_id": "sensor-xmeas-10", "svg_class": "measurement flow-sensor",        "xmeas_number": 10, "name": "Purge Rate",                       "data_xmeas": "10", "data_stream": "9",  "unit": "kscmh", "symbol": "FI" },
