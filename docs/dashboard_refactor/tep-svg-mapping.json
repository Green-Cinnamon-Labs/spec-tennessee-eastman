    { "svg_cell_id": "sensor-xmeas-12", "svg_class": "measurement level-sensor",       "xmeas_number": 12, "name": "Separator Level",                  "data_xmeas": "12", "data_unit": "unit-separator",   "unit": "%",     "symbol": "LI", "critical": true },
    { "svg_cell_id": "sensor-xmeas-13", "svg_class": "measurement pressure-sensor",    "xmeas_number": 13, "name": "Separator Pressure",               "data_xmeas": "13", "data_unit": "unit-separator",   "unit": "kPa",   "symbol": "PI" },
    { "svg_cell_id": "sensor-xmeas-14", "svg_class": "measurement flow-sensor",        "xmeas_number": 14, "name": "Separator Underflow",              "data_xmeas": "14", "data_stream": "10", "unit": "m³/hr", "symbol": "FI" },
    { "svg_cell_id": "sensor-xmeas-15", "svg_class": "measurement level-sensor",       "xmeas_number": 15, "name": "Stripper Level",                   "data_xmeas": "15", "data_unit": "unit-stripper",    "unit": "%",     "symbol": "LI", "critical": true },
    { "svg_cell_id": "sensor-xmeas-16", "svg_class": "measurement pressure-sensor",    "xmeas_number": 16, "name": "Stripper Pressure",                "data_xmeas": "16", "data_unit": "unit-stripper",    "unit": "kPa",   "symbol": "PI" },
    { "svg_cell_id": "sensor-xmeas-17", "svg_class": "measurement flow-sensor",        "xmeas_number": 17, "name": "Stripper Underflow",               "data_xmeas": "17", "data_stream": "11", "unit": "m³/hr", "symbol": "FI" },
