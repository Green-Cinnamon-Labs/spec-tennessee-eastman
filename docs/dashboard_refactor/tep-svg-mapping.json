{
  "$schema": "TEP SVG Semantic Mapping",
  "title": "Tennessee Eastman Process — SVG data-cell-id Mapping",
  "description": "Translates abstract ontology (XMV, XMEAS, streams) to concrete SVG semantic structure. Source of truth for draw.io SVG addressing and JavaScript binding.",
  "version": "2.0.0",
  "date": "2026-05-21",

  "svg_addressing": {
    "attribute": "data-cell-id",
    "selector_pattern": "[data-cell-id='<id>']",
    "prefix_selector": "[data-cell-id^='<prefix>-']",
    "note": "O draw.io exporta o SVG com data-cell-id, não id. Usar querySelector, não getElementById."
  },

  "units": [
    {
      "svg_cell_id": "unit-reactor",
      "svg_class": "unit vessel",
      "name": "Reactor",
      "data_unit": "reactor",
      "xmeas_inline": [7, 8, 9],
      "xmeas_description": "pressure (7), level (8), temperature (9)",
      "xmv_controlled_by": [3, 4, 5, 10, 12],
      "note": "Reator onde as reações ocorrem (TCR, exotérmico)"
    },
    {
      "svg_cell_id": "unit-condenser",
      "svg_class": "unit heat-exchanger",
      "name": "Condenser",
      "data_unit": "condenser",
      "xmeas_inline": [],
      "xmv_controlled_by": [11],
      "note": "Condensador do produto do reator; sem holdup dinâmico principal"
    },
    {
      "svg_cell_id": "unit-separator",
      "svg_class": "unit vessel",
      "name": "Separator",
      "data_unit": "separator",
      "xmeas_inline": [11, 12, 13, 14],
      "xmeas_description": "temperature (11), level (12), pressure (13), underflow (14)",
      "xmv_controlled_by": [7, 11],
      "note": "Vapor-liquid separator; separa vapor reciclável/purga e líquido"
    },
    {
      "svg_cell_id": "unit-compressor-1",
      "svg_class": "unit machine",
      "name": "Compressor (stage 1)",
      "data_unit": "compressor",
      "xmeas_inline": [20],
      "xmeas_description": "work (20) — shared across compressor stages",
      "xmv_controlled_by": [5],
      "note": "Estágio 1 do compressor de reciclo"
    },
    {
      "svg_cell_id": "unit-compressor-2",
      "svg_class": "unit machine",
      "name": "Compressor (stage 2)",
      "data_unit": "compressor",
      "xmeas_inline": [],
      "xmv_controlled_by": [5],
      "note": "Estágio 2 do compressor de reciclo"
    },
    {
      "svg_cell_id": "unit-compressor-3",
      "svg_class": "unit machine",
      "name": "Compressor (stage 3)",
      "data_unit": "compressor",
      "xmeas_inline": [],
      "xmv_controlled_by": [5],
      "note": "Estágio 3 do compressor de reciclo"
    },
    {
      "svg_cell_id": "unit-stripper",
      "svg_class": "unit vessel",
      "name": "Stripper",
      "data_unit": "stripper",
      "xmeas_inline": [15, 16, 18, 19],
      "xmeas_description": "level (15), pressure (16), temperature (18), steam-flow (19)",
      "xmv_controlled_by": [8, 9],
      "note": "Product stripper; remove componentes leves do produto líquido"
    },
    {
      "svg_cell_id": "unit-stripper-boiler",
      "svg_class": "unit heat-exchanger",
      "name": "Stripper Reboiler",
      "data_unit": "stripper-boiler",
      "xmeas_inline": [19],
      "xmeas_description": "steam flow (19)",
      "xmv_controlled_by": [9],
      "note": "Reboiler da base do stripper; utiliza vapor XMV(9) para aquecimento"
    },
    {
      "svg_cell_id": "node-reactor-feed-mixer",
      "svg_class": "node mixer",
      "name": "Reactor Feed Mixer",
      "note": "Nó de mistura de todas as alimentações do reator (streams 01, 02, 03, 04, 05, 08)"
    }
  ],

  "streams": [
    {
      "stream_number": 1,
      "name": "A Feed",
      "ontology_id": "stream-feed-A",
      "svg_source": "data-01-a-feed",
      "svg_segments": ["stream-01-a-feed-up", "stream-01-a-feed-down"],
      "svg_class": "stream gas feed",
      "data_xmeas": "1",
      "data_xmv": "3",
      "data_phase": "gas",
      "description": "Alimentação A (composto A puro, gasoso)",
      "source": "external",
      "destination": "node-reactor-feed-mixer",
      "note": "Sem âncora primária única; binding via sensor-xmeas-01 e actuator-xmv-03"
    },
    {
      "stream_number": 2,
      "name": "D Feed",
      "ontology_id": "stream-feed-D",
      "svg_source": "data-02-d-feed",
      "svg_segments": ["stream-02-d-feed-up", "stream-02-d-feed-down"],
      "svg_class": "stream gas-feed feed",
      "data_xmeas": "2",
      "data_xmv": "1",
      "data_phase": "gas-feed",
      "description": "Alimentação D",
      "source": "external",
      "destination": "node-reactor-feed-mixer"
    },
    {
      "stream_number": 3,
      "name": "E Feed",
      "ontology_id": "stream-feed-E",
      "svg_source": "data-03-e-feed",
      "svg_segments": ["stream-03-e-feed-up", "stream-03-e-feed-down"],
      "svg_class": "stream gas-feed feed",
      "data_xmeas": "3",
      "data_xmv": "2",
      "data_phase": "gas-feed",
      "description": "Alimentação E",
      "source": "external",
      "destination": "node-reactor-feed-mixer"
    },
    {
      "stream_number": 4,
      "name": "A/C Feed (C Feed)",
      "ontology_id": "stream-feed-AC",
      "svg_source": "data-04-c-feed",
      "svg_segments": ["stream-04-c-feed-up", "stream-04-c-feed-down"],
      "svg_class": "stream gas feed",
      "data_xmeas": "4",
      "data_xmv": "4",
      "data_phase": "gas",
      "description": "Alimentação A + C (razão variável por IDV 1); alimenta o stripper, não diretamente o reator",
      "source": "external",
      "destination": "unit-stripper",
      "note": "ID renomeado de ac-feed para c-feed — decisão deliberada no draw.io"
    },
    {
      "stream_number": 5,
      "name": "Stripper Overhead",
      "ontology_id": "stream-stripper-overhead",
      "svg_cell_id": "stream-05-stripper-mixer",
      "svg_segments": ["stream-05-stripper-mixer"],
      "svg_class": "stream gas overhead recycle",
      "data_phase": "gas",
      "description": "Topo do stripper retorna ao nó de mistura de alimentação do reator",
      "source": "unit-stripper",
      "destination": "node-reactor-feed-mixer"
    },
    {
      "stream_number": 6,
      "name": "Reactor Feed (Total)",
      "ontology_id": "stream-reactor-feed",
      "svg_cell_id": "stream-06-mixer-reactor",
      "svg_segments": ["stream-06-mixer-reactor"],
      "svg_class": "stream mixed reactor-feed",
      "data_xmeas": "6",
      "data_phase": "mixed",
      "data_analyzer": "analyzer-06-feed",
      "description": "Saída do nó de mistura para o reator; ponto de amostragem XMEAS 23-28",
      "source": "node-reactor-feed-mixer",
      "destination": "unit-reactor"
    },
    {
      "stream_number": 7,
      "name": "Reactor Product",
      "ontology_id": "stream-vapor-R-to-S",
      "svg_cell_id": "stream-07-reactor-condenser",
      "svg_segments": ["stream-07-reactor-condenser"],
      "svg_class": "stream vapor product",
      "data_phase": "vapor",
      "description": "Saída do reator → condensador → separador",
      "source": "unit-reactor",
      "destination": "unit-separator",
      "passes_through": "unit-condenser"
    },
    {
      "stream_number": 8,
      "name": "Recycle",
      "ontology_id": "stream-recycle",
      "svg_cell_id": null,
      "svg_segments": ["stream-08-up", "stream-08-down", "stream-08-bypass-up", "stream-08-bypass-down"],
      "svg_class": "stream gas recycle",
      "data_xmeas": "5",
      "data_xmv": "5",
      "data_phase": "gas",
      "description": "Vapor reciclado do compressor para reator; tem bypass com válvula XMV(5)",
      "source": "unit-compressor-1",
      "destination": "node-reactor-feed-mixer",
      "note": "Sem âncora primária — binding via sensor-xmeas-05 e actuator-xmv-05; selecionar segmentos via [data-cell-id^='stream-08-']"
    },
    {
      "stream_number": 9,
      "name": "Purge",
      "ontology_id": "stream-purge",
      "svg_cell_id": "stream-09-purge",
      "svg_segments": ["stream-09-purge", "stream-09-up", "stream-09-down"],
      "svg_class": "stream gas purge",
      "data_xmeas": "10",
      "data_xmv": "6",
      "data_phase": "gas",
      "data_analyzer": "analyzer-09-purge",
      "description": "Purga de gases não-condensáveis; ponto de amostragem XMEAS 29-36",
      "source": "unit-separator",
      "destination": "external"
    },
    {
      "stream_number": 10,
      "name": "Separator Underflow",
      "ontology_id": "stream-liquid-S-to-C",
      "svg_cell_id": "stream-10-in",
      "svg_segments": ["stream-10-in", "stream-10-out", "stream-10-up", "stream-10-down"],
      "svg_class": "stream liquid separator-underflow",
      "data_xmeas": "14",
      "data_xmv": "7",
      "data_phase": "liquid",
      "description": "Líquido do separador para stripper (bottoms)",
      "source": "unit-separator",
      "destination": "unit-stripper",
      "note": "stream-10-in é o segmento mais próximo do ponto de medição"
    },
    {
      "stream_number": 11,
      "name": "Product",
      "ontology_id": "stream-product-bottoms",
      "svg_cell_id": "stream-11-product",
      "svg_segments": ["stream-11-product", "stream-11-up", "stream-11-down"],
      "svg_class": "stream liquid product",
      "data_xmeas": "17",
      "data_xmv": "8",
      "data_phase": "liquid",
      "data_analyzer": "analyzer-11-product",
      "description": "Produto final (saída do stripper); ponto de amostragem XMEAS 37-41",
      "source": "unit-stripper",
      "destination": "external",
      "product_exit": "product-stream"
    },
    {
      "stream_number": 12,
      "name": "Reactor CW",
      "ontology_id": "stream-CW-reactor",
      "svg_cell_id": "stream-cws-reactor-in",
      "svg_segments": ["stream-cws-reactor-in", "stream-cws-reactor-out", "stream-cws-reactor-up"],
      "svg_class": "stream utility cooling-water reactor-cw",
      "data_xmv": "10",
      "data_xmeas": "21",
      "data_phase": "utility",
      "description": "Água de resfriamento para jaqueta do reator (outlet: XMEAS 21)",
      "source": "external",
      "destination": "unit-reactor",
      "outlet_element": "stream-cws-reactor-out",
      "utility_type": "cooling-water",
      "note": "ID renomeado de stream-12-reactor-cw para padrão cws-*"
    },
    {
      "stream_number": 13,
      "name": "Condenser CW",
      "ontology_id": "stream-CW-condenser",
      "svg_cell_id": "stream-cws-condenser-in",
      "svg_segments": ["stream-cws-condenser-in", "stream-cws-condenser-out"],
      "svg_class": "stream utility cooling-water condenser-cw",
      "data_xmv": "11",
      "data_xmeas": "22",
      "data_phase": "utility",
      "description": "Água de resfriamento para condensador (outlet: XMEAS 22)",
      "source": "external",
      "destination": "unit-condenser",
      "outlet_element": "stream-cws-condenser-out",
      "utility_type": "cooling-water",
      "note": "ID renomeado de stream-13-condenser-cw para padrão cws-*"
    },
    {
      "stream_number": null,
      "name": "Stripper Steam (boiler circuit)",
      "ontology_id": "stream-stripper-steam",
      "svg_cell_id": "stream-stm-boiler-in",
      "svg_segments": ["stream-stm-boiler-in", "stream-stm-boiler-down", "stream-cond-boiler-out"],
      "svg_class": "stream utility steam stripper-steam",
      "data_xmv": "9",
      "data_xmeas": "19",
      "data_phase": "vapor",
      "description": "Vapor de aquecimento para o reboiler do stripper; condensado retorna via stream-cond-boiler-out",
      "source": "external",
      "destination": "unit-stripper-boiler",
      "utility_type": "steam"
    },
    {
      "stream_number": null,
      "name": "Stripper Boiler Process Circuit",
      "ontology_id": null,
      "svg_cell_id": "stream-stripper-boiler-in",
      "svg_segments": ["stream-stripper-boiler-in", "stream-stripper-boiler-out"],
      "svg_class": "stream process stripper-boiler",
      "data_phase": "liquid",
      "description": "Circulação de processo (líquido do stripper) pelo reboiler",
      "source": "unit-stripper",
      "destination": "unit-stripper-boiler"
    }
  ],

  "actuators": [
